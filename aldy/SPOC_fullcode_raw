import numpy as np
from scipy.stats import qmc
import time
import warnings

# ================================================================
#  CORE SDOA & CLUSTERING IMPLEMENTATION (Diophantine Version)
# ================================================================

def get_rotation_matrix(n, theta):
    """Build n-dim rotation matrix."""
    if n == 1:
        return np.array([[-1.0]])

    c, s = np.cos(theta), np.sin(theta)
    R_total = np.identity(n)
    for i in range(n - 1):
        for j in range(i + 1, n):
            R_ij = np.identity(n)
            R_ij[i, i] =  c;  R_ij[i, j] = -s
            R_ij[j, i] =  s;  R_ij[j, j] =  c
            R_total = R_total @ R_ij
    return R_total

def create_continuous_bounds(integer_domain, margin=0.5):
    """
    Memperluas setiap dimensi integer_domain sebesar margin ke kiri dan kanan.
    Titik spiral bebas bergerak di sini, tanpa dipotong.
    """
    continuous_bounds = []
    for lo, hi in integer_domain:
        continuous_bounds.append((lo - margin, hi + margin))
    return continuous_bounds

def is_in_domain(point, domain):
    """Check if a point is within the domain boundaries."""
    for i, (lo, hi) in enumerate(domain):
        if not (lo <= point[i] <= hi):
            return False
    return True

def objective_function(x, system_of_equations, integer_domain):
    """
    Evaluasi hanya jika hasil pembulatan x berada dalam integer_domain.
    Jika di luar, kembalikan 0.0 (nilai terburuk).
    """
    q = np.round(x).astype(object)

    if not is_in_domain(q, integer_domain):
        return 0.0
    try:
        sum_abs_f = sum(abs(f_i(q)) for f_i in system_of_equations)
        return 1.0 / (1.0 + float(sum_abs_f))
    except (OverflowError, ZeroDivisionError):
        return 0.0

def generate_sobol_points(num_points, dimension, domain):
    """Generate Sobol points scaled to domain."""
    lower_bounds = np.array([d[0] for d in domain])
    upper_bounds = np.array([d[1] for d in domain])

    sampler = qmc.Sobol(d=dimension, scramble=False)
    unit_points = sampler.random(n=num_points)
    return qmc.scale(unit_points, lower_bounds, upper_bounds)

class Cluster:
    def __init__(self, center, radius):
        """
        Inisialisasi Cluster.
        """
        self.center = np.array(center, dtype=float)
        self.radius = float(radius)

    def __repr__(self):
        return f"Cluster(center={self.center.round(4)}, radius={self.radius:.4f})"

def process_point_for_clustering(y, clusters, equations, integer_domain, gamma, continuous_bounds, F_y=None, num_check_points=1):
    if F_y is None:
        F_y = objective_function(y, equations, integer_domain)

    # Syarat mutlak pemotongan nilai nol (cutting off value)
    if F_y <= gamma:
        return clusters

    # Langkah 6a & 6b: Cari cluster terdekat
    min_dist = float('inf')
    nearest_cluster = None
    for cluster in clusters:
        dist = np.linalg.norm(y - cluster.center)
        if dist < min_dist:
            min_dist = dist
            nearest_cluster = cluster

    x_C = nearest_cluster.center
    F_xC = objective_function(x_C, equations, integer_domain)

    # Langkah 6c: Titik tengah HARUS tetap di ruang riil, tanpa np.round
    t_vals = [i / (num_check_points + 1) for i in range(1, num_check_points + 1)]
    x_ts = [y + t * (x_C - y) for t in t_vals]
    F_xts = [objective_function(x_t, equations, integer_domain) for x_t in x_ts]

    F_xts_min = min(F_xts)
    F_xts_max = max(F_xts)

    dist_half = np.linalg.norm(y - x_C)/2

    # new_dist = np.linalg.norm(y - x_t)

    # Langkah 6d & 6e: Logika pembentukan cluster baru atau pembaruan radius
    if F_xts_min < F_y and F_xts_min < F_xC:
        clusters.append(Cluster(y, dist_half))

    elif F_xts_max > F_y and F_xts_max > F_xC:
        clusters.append(Cluster(y, dist_half))
        # Pemanggilan rekursif dengan input y = x_t
        x_ts_best = x_ts[F_xts.index(F_xts_max)]
        clusters = process_point_for_clustering(x_ts_best, clusters, equations, integer_domain, gamma, continuous_bounds, F_y=F_xts_max)

    elif F_y > F_xC:
        # y mendominasi x_C, sehingga y menjadi pusat cluster baru untuk C
        nearest_cluster.center = y.copy()

    nearest_cluster.radius = dist_half
    return clusters

def perform_iterative_clustering(equations, integer_domain, continuous_bounds, params):
    """
    Fase 1: Clustering dengan adaptasi Diophantine.
    """
    m_cluster, gamma, k_cluster = params['m_cluster'], params['gamma'], params['k_cluster']
    r, theta = params['r'], params['theta']
    num_check_points = params.get('num_check_points', 1)

    n = len(integer_domain)

    # Langkah 1: Generate initial points (titik riil)
    points = generate_sobol_points(m_cluster, n, continuous_bounds)
    R_n = get_rotation_matrix(n, theta)
    S_n = r * R_n
    diff_S = S_n - np.identity(n)
    clusters = []

    obj_func = lambda x: objective_function(x, equations, integer_domain)

    # Langkah 3, 4, & 5: Inisialisasi eksplisit Cluster Pertama (C1)
    rounded_points_init = np.round(points)
    F_values_init = np.array([obj_func(p) for p in rounded_points_init])
    best_idx_init = np.argmax(F_values_init)
    x_star_init = rounded_points_init[best_idx_init].copy()
    x_star = x_star_init

    initial_radius = 0.5 * float(min(hi - lo for lo, hi in continuous_bounds))
    clusters.append(Cluster(x_star_init, initial_radius))

    # Langkah 6-10: Siklus iterasi clustering
    for k in range(k_cluster):
        # Langkah 7: Definisikan q_i(k), precomputed untuk langkah 6 dan 8
        rounded_points = np.round(points)

        # Langkah 6: Logika penambahan cluster
        F_cache = {}
        center_set = {tuple(np.round(c.center).astype(int).tolist()) for c in clusters}

        for i in range(m_cluster):
            if is_in_domain(rounded_points[i], integer_domain):
                F_val = obj_func(points[i])
                F_cache[i] = F_val

        for i, F_val in F_cache.items():
            if F_val > gamma:
                key = tuple(rounded_points[i].astype(int).tolist())
                if key not in center_set:
                    clusters = process_point_for_clustering(points[i], clusters, equations, integer_domain, gamma, continuous_bounds, F_y=F_val, num_check_points=num_check_points)
                    center_set.add(key)

        # Langkah 8: Temukan titik bulat terbaik untuk rotasi
        if F_cache:   # ← hanya update x_star jika ada titik valid
            best_idx = max(F_cache, key=F_cache.get)
            x_star = rounded_points[best_idx].copy()

        # Langkah 9: Transformasi Spiral (tetap di ruang riil)
        points = points @ S_n.T - diff_S @ x_star

    # Langkah 11: Pembulatan definitif pusat cluster di akhir Fase 1
    for c in clusters:
        c.center = np.round(c.center)

    return clusters

def spiral_dynamics_optimization(objective_func, continuous_bounds, params, custom_initial_points=None, epsilon=1e-7):
    """
    Fase 2: Optimasi SDOA pada ruang riil dengan evaluasi diskret.
    """
    m, r, theta, k_max = params['m'], params['r'], params['theta'], params['k_max']
    n = len(continuous_bounds)

    if custom_initial_points is not None:
        search_points = np.array(custom_initial_points)
        m = len(search_points)
    else:
        search_points = generate_sobol_points(m, n, continuous_bounds)

    R_n = get_rotation_matrix(n, theta)
    S_n = r * R_n
    diff_S = S_n - np.identity(n)

    # Inisialisasi memori Global Best untuk mencegah amnesia algoritma
    global_best_val = -1.0
    global_best_x = None

    for k in range(k_max):
        rounded_points = np.round(search_points)

        vals = np.array([objective_func(sp) for sp in search_points])
        best_idx = np.argmax(vals)

        if vals[best_idx] > global_best_val:
            global_best_val = vals[best_idx]
            global_best_x = rounded_points[best_idx].copy()

        # Gunakan global_best_x sebagai pusat gravitasi rotasi spiral (x*)
        if global_best_x is None:
            # Belum ada titik valid ditemukan, transformasi tidak bisa dilakukan
            # Lanjut ke iterasi berikutnya tanpa menggerakkan points
            continue

        # Early stopping: Jika residual memenuhi syarat epsilon, hentikan iterasi
        if 1.0 - global_best_val <= epsilon:
            return global_best_x

        x_star = global_best_x

        # Rotasi matriks di ruang kontinu
        search_points = search_points @ S_n.T - diff_S @ x_star

    return global_best_x if global_best_x is not None else rounded_points[0]

def run_sdoa_on_clusters(clusters, equations, integer_domain, continuous_bounds, sdoa_params, epsilon):
    """
    Fase 2: Eksekusi SDOA terisolasi pada masing-masing sub-domain cluster.
    """
    candidates = []

    cluster_objective = lambda x: objective_function(x, equations, integer_domain)

    for cluster in clusters:
        cluster_domain = []

        # Radius minimal dipaksa 1.0 agar mencakup setidaknya integer tetangga terdekat.
        effective_radius = max(cluster.radius, 1.0)

        for dim in range(len(integer_domain)):
            c_lo = max(continuous_bounds[dim][0], cluster.center[dim] - effective_radius)
            c_hi = min(continuous_bounds[dim][1], cluster.center[dim] + effective_radius)

            if c_lo >= c_hi:
                mid = (continuous_bounds[dim][0] + continuous_bounds[dim][1]) / 2.0
                half = max(0.5, (continuous_bounds[dim][1] - continuous_bounds[dim][0]) / 2.0)
                c_lo = max(continuous_bounds[dim][0], mid - half)
                c_hi = min(continuous_bounds[dim][1], mid + half)

            cluster_domain.append((c_lo, c_hi))

        # Bangkitkan titik awal populasi SDOA di dalam sub-domain cluster yang aman
        initial_points = generate_sobol_points(sdoa_params['m'], len(integer_domain), cluster_domain)

        candidate = spiral_dynamics_optimization(
            cluster_objective, continuous_bounds, sdoa_params,
            custom_initial_points=initial_points, epsilon=epsilon
        )

        candidates.append(candidate)

    return np.array(candidates) if candidates else np.empty((0, len(integer_domain)))

def select_final_roots(candidates, equations, integer_domain, epsilon, delta):
    """
    Fase 3: Seleksi root unik sesuai Langkah 13 & 14.
    """
    accurate_candidates = []

    for cand in candidates:
        # Konversi array NumPy ke tipe integer murni, lalu ke list native Python
        cand_int_native = np.round(cand).astype(int)

        # Evaluasi batas menggunakan integer native
        if not is_in_domain(cand_int_native, integer_domain):
            continue

        F_val = objective_function(cand, equations, integer_domain)

        # Sesuai Langkah 13: harus <= epsilon
        if 1.0 - F_val <= epsilon:
            accurate_candidates.append((cand_int_native, F_val))

    if not accurate_candidates:
        return []

    accurate_candidates.sort(key=lambda x: x[1], reverse=True)
    final_roots = []

    for cand, F_val in accurate_candidates:
        found_close = False

        for existing, _ in final_roots:
            # Sesuai Langkah 14: Evaluasi jarak Euclidean
            if np.linalg.norm(cand - existing) <= delta:
                found_close = True
                break

        if not found_close:
            final_roots.append((cand, F_val))
    return [tuple(root.tolist()) for root, _ in final_roots]

def sort_unique_roots(roots, sort=False):
    """
    Menghapus solusi duplikat dengan mengabaikan urutan dalam solusi.
    Parameter:
        roots : list of tuple
        sort : bool
            Jika True -> simpan versi sorted setiap solusi, lalu urutkan hasil akhir.
            Jika False -> simpan versi asli (kemunculan pertama), tanpa pengurutan akhir.
    """
    seen = set()
    unique = []
    for root in roots:
        key = tuple(sorted(root))
        if key not in seen:
            seen.add(key)
            if sort:
                unique.append(key)
            else:
                unique.append(tuple(root))
    if sort:
        unique.sort()
    return unique

