def problem_1():
    """15x + 11y = 12 (Linear)"""
    equations = [lambda d: (
        60.0*d[0] + 70.0*d[1] + 30.0*d[2] + 80.0*d[3] + 90.0*d[4] +
        40.0*d[5] + 55.0*d[6] + 65.0*d[7] + 55.0*d[8] + 200.0*d[9] +
        180.0*d[10] + 30.0*d[11] + 80.0*d[12] + 130.0*d[13] + 110.0*d[14] +
        50.0*d[15] + 40.0*d[16] + 250.0*d[17] + 40.0*d[18] + 20.0*d[19] +
        10.0*d[20] + 10.0*d[21] + 30.0*d[22] + 40.0*d[23] + 0.0*d[24] - 38690
    )]
    domain = [
        (7, 10), (7, 10), (5, 7), (18, 22), (25, 30),
        (6, 8), (12, 17), (25, 30), (14, 19), (25, 30),
        (20, 30), (4, 5), (15, 20), (25, 30), (25, 30),
        (15, 20), (3, 5), (18, 23), (8, 12), (1, 1),
        (1, 1), (1, 1), (6, 9), (10, 14), (1, 1)
    ]

    params = {
        'm_cluster': 6500,
        'k_cluster': 490,
        'gamma': 1e-5,
        'epsilon': 1e-7, 'delta': 0.1, 'r': 0.984, 'theta': 9*np.pi/80,
        'sdoa_m': 100, 'sdoa_k_max': 75, 'sdoa_r': 0.977, 'sdoa_theta': np.pi/16,
        'num_check_points': 3
    }
    return equations, domain, params, 0

# ================================================================
#  MAIN ALGORITHM & RUNNER
# ================================================================

def solve_diophantine_soac(problem_func, sort_solutions=False):
    """
    Fungsi utama orkestrasi SOAC.
    Menjalankan simulasi dan memvalidasi output secara eksplisit.
    """
    equations, integer_domain, params, expected = problem_func()
    epsilon = params['epsilon']
    continuous_bounds = create_continuous_bounds(integer_domain, margin=0.5)
    print("="*70)
    print(f"DIOPHANTINE EQUATION SOLVER (SOAC)")
    print(f"Integer domain        : {integer_domain}")
    print(f"Continuous bounds     : {continuous_bounds}  (margin = 0.5)")
    print(f"Target: Integer roots | Dimension: {len(integer_domain)}D | Epsilon: {epsilon}")
    print("="*70)
    start_time = time.time()
    # Eksekusi 3 Fase Utama SOAC
    clusters = perform_iterative_clustering(equations, integer_domain, continuous_bounds, params)
    sdoa_params = {
        'm': params['sdoa_m'],
        'r': params['sdoa_r'],
        'theta': params['sdoa_theta'],
        'k_max': params['sdoa_k_max']
    }
    candidates = run_sdoa_on_clusters(clusters, equations, integer_domain, continuous_bounds, sdoa_params, epsilon)
    valid_roots = select_final_roots(candidates, equations, integer_domain, epsilon, params['delta'])
    if sort_solutions:
        valid_roots = sort_unique_roots(valid_roots, sort=True)
    else:
        valid_roots = sort_unique_roots(valid_roots, sort=False)  # tetap hapus duplikat identik
    elapsed_time = time.time() - start_time
    # Pelaporan Hasil
    print(f"\n[HASIL OPTIMASI]")
    print(f"• Waktu Eksekusi   : {elapsed_time:.3f} detik")
    print(f"• Cluster Terpadu  : {len(clusters)}")
    print(f"• Solusi Ditemukan : {len(valid_roots)} (Ekspektasi literatur: {expected})")
    print("-" * 70)
    if len(valid_roots) > 0:
        for i, root in enumerate(valid_roots):
            F_val = objective_function(root, equations, integer_domain)
            residual = 1.0 - F_val
            print(f"  Solusi {i+1:<2} ➔ {root} | F(x): {F_val:.6f} | Res: {residual:.2e}")
    else:
        print("  [!] Tidak ada solusi bilangan bulat yang memenuhi kriteria epsilon.")
    print("="*70 + "\n")
    return valid_roots

if __name__ == "__main__":
    solve_diophantine_soac(problem_1, sort_solutions=True)
